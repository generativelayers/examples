/* Jason Project — Two-Agent Assessment
 *
 * The Generator invokes the generative layer, the Assessor peer-reviews,
 * and the Generator makes the final adoption decision.
 *
 * Demonstrates:
 *   - Inter-agent assessment via KQML messages
 *   - Assessment as a first-class Generative Layer artifact
 *   - Agent autonomy — the Generator decides, not the LLM or the Assessor
 *   - Full traceability of the candidate lifecycle
 */

MAS two_agent_assessment {
    agents:
        generator;
        assessor;
}
