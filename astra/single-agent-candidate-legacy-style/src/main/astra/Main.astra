// Pipeline: main > !banner > !classified(food) > !invoked > !deliberated > accept|reject
/**
 * Single Agent Candidate (Legacy Style) - ASTRA
 *
 * Demonstrates the legacy approach to candidate generation, using
 * global gl.configure and gl.use_provider, and invoking the LLM via
 * gl.invoke instead of the agent-scoped bindings.
 */
agent Main {
    module gl.astra.GL gl;
    module Console console;
    module System S;

    types governance {
        formula classified(string, string, string);
        formula accepted(string);
        formula rejected(string, string);
    }

    // DOMAIN MODEL
    inference classified(string item, string label, string conf) :-
        accepted(string _) & classified(item, label, conf);

    // DECOMPOSITION: main only adopts subgoals
    rule +!main(list args) {
        !banner();
        gl.configure("model", "gpt-oss-120b");
        gl.use_provider("cerebras");
        !classified("apple");
        !shutdown();
    }

    // ACHIEVEMENT: clean exit (actions only)
    rule +!shutdown() {
        S.exit();
    }

    // ACHIEVEMENT: display banner
    rule +!banner() {
        console.println("=== Generative Layer Single Agent Candidate Demo (Legacy Style) ===");
        console.println("");
        console.println("[Layer] Available providers: " + gl.providers());
    }

    // DECOMPOSITION: classify = invoke + deliberate
    rule +!classified(string foodItem) {
        !invoked(gl.invoke(
            "agent_a", "classify_food", "llm.answer", "ANSWER",
            "Classify the food item '" + foodItem + "'. What category does it belong to? (e.g. fruit, vegetable, grain, dairy, meat). Return label (the category) and confidence (0 to 1).",
            "label,confidence"));
    }

    // DECOMPOSITION: bind rid once ' log ' deliberate
    rule +!invoked(string rid) {
        !log_invocation(rid);
        !deliberated(rid);
    }

    // ACHIEVEMENT: log invocation result
    rule +!log_invocation(string rid) {
        console.println("[Layer] resultId  = " + rid);
    }

    // SERENDIPITY: already accepted
    rule +!deliberated(string rid) : accepted(rid) {
        console.println("[AGENT] Already deliberated: " + rid);
    }

    // DECOMPOSITION: valid + admissible ' accept + trace
    rule +!deliberated(string rid) : gl.valid(rid) == true & gl.admissible(gl.candidate(rid)) == true {
        !accepted_candidate(rid, gl.candidate(rid));
        !print_trace(rid);
    }

    // DECOMPOSITION: valid but not admissible ' reject + trace
    rule +!deliberated(string rid) : gl.valid(rid) == true & gl.admissible(gl.candidate(rid)) == false {
        !rejected_candidate(gl.candidate(rid), rid);
        !print_trace(rid);
    }

    // DECOMPOSITION: invalid ' reject + trace
    rule +!deliberated(string rid) : gl.valid(rid) == false {
        !rejected_candidate("", rid);
        !print_trace(rid);
    }

    // ACHIEVEMENT: accept (actions only)
    rule +!accepted_candidate(string rid, string cid) {
        console.println("");
        console.println("[AGENT] Candidate is valid and admissible.");
        console.println("[AGENT]   label      = " + gl.field(rid, "label"));
        console.println("[AGENT]   confidence = " + gl.field(rid, "confidence"));
        gl.accept(cid);
        +accepted(cid);
        +classified("food", gl.field(rid, "label"), gl.field(rid, "confidence"));
        console.println("[AGENT] Candidate ACCEPTED. Belief adopted.");
    }

    // ACHIEVEMENT: reject (actions only)
    rule +!rejected_candidate(string cid, string rid) {
        if (cid ~= "") {
            gl.reject(cid);
        }
        +rejected(cid, gl.outcome(rid));
        console.println("");
        console.println("[AGENT] Candidate REJECTED.");
        console.println("[AGENT]   outcome = " + gl.outcome(rid));
    }

    // ACHIEVEMENT: print trace (actions only)
    rule +!print_trace(string rid) {
        console.println("");
        console.println("[TRACE] traceId = " + gl.trace(rid));
        console.println("=== Demo Complete ===");
    }

    // RECOVERY: only fire when no candidate was accepted (genuine failure)
    rule -!classified(string foodItem) : ~accepted(string _) {
        console.println("[AGENT] Classification FAILED for " + foodItem);
    }

    rule -!invoked(string rid) : ~accepted(string _) {
        console.println("[AGENT] Invocation handling FAILED for " + rid);
    }

    rule -!deliberated(string rid) : ~accepted(string _) {
        console.println("[AGENT] Deliberation FAILED for " + rid);
    }
}
