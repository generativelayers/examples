// Pipeline: main > !banner > !setup > !classified(food) > !deliberated > accept|reject
/**
 * Single Agent Candidate (Legacy Style) - ASTRA
 *
 * Demonstrates the migrated approach to candidate generation, using
 * agent-scoped bindings and v2 commands.
 */
agent Main {
    module gl.astra.GL gl;
    module Console console;
    module System S;

    types governance {
        formula binding(string);
        formula classified(string, string, string);
        formula accepted(string);
        formula rejected(string, string);
    }

    // DOMAIN MODEL
    inference classified(string item, string label, string conf) :-
        accepted(string _) & classified(item, label, conf);

    // DECOMPOSITION: main only adopts subgoals
    rule +!main(list args) {
        !banner();
        !setup();
        !classified("apple");
        !shutdown();
    }

    // ACHIEVEMENT: clean exit (actions only)
    rule +!shutdown() {
        S.exit();
    }

    // ACHIEVEMENT: display banner
    rule +!banner() {
        console.println("=== Generative Layer Single Agent Candidate Demo (Legacy Style) ===");
        console.println("");
        console.println("[Layer] Available providers: " + gl.see());
    }

    // ACHIEVEMENT: setup binding
    rule +!setup() {
        +binding(gl.bind("agent_a", "groq", "llama-3.3-70b-versatile", ""));
    }

    // DECOMPOSITION: classify = invoke + deliberate
    rule +!classified(string foodItem) : binding(string bid) {
        !deliberated(gl.call(bid, "classify_food", "llm.answer", "ANSWER",
            "Classify the food item '" + foodItem + "'. What category does it belong to? (e.g. fruit, vegetable, grain, dairy, meat). Return label (the category) and confidence (0 to 1).",
            "label,confidence", ""));
    }

    // DECOMPOSITION: handle deliberation based on outcome
    rule +!deliberated(string rid) : gl.decide(gl.candidate(rid)) == "ADMISSIBLE" {
        !accepted_candidate(rid, gl.candidate(rid));
        !print_trace(rid);
    }

    rule +!deliberated(string rid) {
        !rejected_candidate(gl.candidate(rid), rid);
        !print_trace(rid);
    }

    // ACHIEVEMENT: accept (actions only)
    rule +!accepted_candidate(string rid, string cid) {
        console.println("");
        console.println("[AGENT] Candidate is valid and admissible.");
        console.println("[AGENT]   label      = " + gl.get(cid, "label"));
        console.println("[AGENT]   confidence = " + gl.get(cid, "confidence"));
        gl.accept(cid, "admissible output");
        +accepted(cid);
        +classified("food", gl.get(cid, "label"), gl.get(cid, "confidence"));
        console.println("[AGENT] Candidate ACCEPTED. Belief adopted.");
    }

    // ACHIEVEMENT: reject (actions only) - candidate exists
    rule +!rejected_candidate(string cid, string rid) : cid ~= "" {
        gl.reject(cid, "failed validation/deliberation");
        +rejected(cid, gl.decide(cid));
        console.println("");
        console.println("[AGENT] Candidate REJECTED.");
        console.println("[AGENT]   outcome = " + gl.decide(cid));
    }

    // ACHIEVEMENT: reject (actions only) - no candidate
    rule +!rejected_candidate(string cid, string rid) : cid == "" {
        +rejected(cid, gl.decide(cid));
        console.println("");
        console.println("[AGENT] Candidate REJECTED.");
        console.println("[AGENT]   outcome = " + gl.decide(cid));
    }

    // ACHIEVEMENT: print trace (actions only)
    rule +!print_trace(string rid) {
        console.println("");
        console.println("[TRACE] traceId = " + gl.explain(rid));
        console.println("=== Demo Complete ===");
    }

    // RECOVERY: only fire when no candidate was accepted (genuine failure)
    rule -!classified(string foodItem) : ~accepted(string _) {
        console.println("[AGENT] Classification FAILED for " + foodItem);
    }

    rule -!deliberated(string rid) : ~accepted(string _) {
        console.println("[AGENT] Deliberation FAILED for " + rid);
    }
}
