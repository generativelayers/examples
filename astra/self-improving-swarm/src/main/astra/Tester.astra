/**
 * Tester Agent (B) — Automated Compilation & Unit Test Simulator.
 *
 * Runs stateless evaluations of candidate Java code using Cerebras (gpt-oss-120b).
 * Acts as a strict static compiler and test suite validator.
 */
agent Tester {
    module gl.adapter.astra.AstraAdapter gl;
    module Console console;

    types tester_types {
        // Domain beliefs
        formula completed_module(string, string);             // storyId, finalCode
        formula test_passed(string, int);                     // storyId, revision

        // FIPA protocols
        formula test_request(string, string, int);            // storyId, codeText, revision
        formula test_failure(string, string, int);            // storyId, errorLog, revision
        formula security_audit_request(string, string, int);  // storyId, codeText, revision
        formula module_finalized(string, string);             // storyId, finalCode
    }

    initial !start();

    rule +!start() {
        console.println("[Tester] Initializing compilation & test simulator...");
        gl.configure("model", "gemini-2.0-flash");
        gl.use_provider("gemini");
    }


    // React to FIPA code test requests from the Developer agent
    rule @message(request, string sender, test_request(string storyId, string codeText, int rev)) {
        console.println("[Tester] Received candidate code (Rev " + rev + ") for verification...");
        console.println("[Tester] Running compiler static analysis and test assertions...");

        // Invoke a stateless GRL ask to run the compilation mock
        string prompt = "Act as a strict Java Compiler and JUnit Test Runner. Analyze the following candidate code:\n"
                      + "```java\n" + codeText + "\n```\n\n"
                      + "Verify if this compiles without errors, has correct return types, and handles negative values correctly. "
                      + "In the schema, set 'compiled' to true or false. If compile or test fails, provide a clear diagnostic error string in 'error_logs'.";

        string rid = gl.invoke("tester", "test_report", "llm.answer", "ANSWER", prompt, "compiled,error_logs");
        !process_test_result(sender, storyId, codeText, rid, rev);
    }

    rule +!process_test_result(string developer, string storyId, string codeText, string rid, int rev) : gl.valid(rid) == true {
        string compiled = gl.field(rid, "compiled");
        string errorLog = gl.field(rid, "error_logs");

        if (compiled == "true") {
            console.println("[Tester] ✅ Compilation and Unit Tests PASSED successfully.");
            +test_passed(storyId, rev);

            // Forward to Security Auditor agent 'auditor' for vulnerability checks
            console.println("[Tester] Forwarding verified code to Security Auditor 'auditor'...");
            send(request, "auditor", security_audit_request(storyId, codeText, rev));
        } else {
            console.println("[Tester] ❌ Compilation/Test FAILED. Reporting diagnostics to Developer...");
            send(inform, developer, test_failure(storyId, errorLog, rev));
        }
    }

    rule +!process_test_result(string developer, string storyId, string codeText, string rid, int rev) : gl.valid(rid) == false {
        console.println("[Tester] Test report validation failed. Defaulting to syntax error.");
        send(inform, developer, test_failure(storyId, "Compilation failed: Syntax/parsing error in generated Java template.", rev));
    }

    // Sync belief base when Developer broadcasts finalized module
    rule @message(inform, string sender, module_finalized(string storyId, string finalCode)) {
        +completed_module(storyId, finalCode);
        console.println("[Tester] Synchronized belief base: module '" + storyId + "' is fully completed.");
    }
}
