/**
 * Developer Agent (A) — Theoretical Software Synthesizer.
 *
 * Configured with Gemini (gemini-2.0-flash) in a completely stateless manner.
 * Manages all conversation history, code revisions, bug reports, and security
 * alerts strictly in its BDI belief base (zero LLM-side memory).
 *
 * Acts like a human programmer by "re-thinking" its beliefs on failure,
 * learning general guidelines, and applying those guidelines to subsequent code generations.
 */
agent Developer {
    module gl.adapter.astra.AstraAdapter gl;
    module Console console;

    types developer_types {
        // Domain beliefs
        formula active_story(string, string);                // storyId, description
        formula candidate_code(string, string, int, string);  // storyId, codeText, revision, candidateId
        formula compilation_error(string, string, int);       // storyId, errorLog, revision
        formula security_violation(string, string, int);      // storyId, vulnerabilityInfo, revision
        formula completed_module(string, string);             // storyId, finalizedCode
        formula active_revision(int);                         // current revision index
        
        // Evolving Cognitive Beliefs
        formula architectural_guideline(string, string);     // ruleName, description
        formula guidelines_context(string);                  // accumulated RAG context of learned rules

        // FIPA protocols
        formula test_request(string, string, int);            // storyId, codeText, revision
        formula test_failure(string, string, int);            // storyId, errorLog, revision
        formula security_violation_msg(string, string, int);  // storyId, vulnerabilityInfo, revision
        formula audit_approved(string, string);               // storyId, finalCode
        formula module_finalized(string, string);             // storyId, finalCode
    }

    // Starting research specification (User Story)
    initial active_story("PaymentProcessor", "Create a Java method signature 'public double calculateFee(double amount, boolean isInternational)' that returns a transaction fee. International transactions must return 5% of amount + 10.0. Domestic transactions must return 1% of amount. If amount is negative, return -1.0.");
    initial active_revision(1);
    
    // Baseline architectural guidelines inside our belief base
    initial guidelines_context("standard coding practice -> write clean, secure, and robust Java methods");
    initial !start();

    rule +!start() {
        console.println("[Developer] Initializing cognitive software engine...");
        gl.configure("model", "gemini-2.0-flash");
        gl.use_provider("gemini");
        !synthesize_initial_code();
    }

    rule +!synthesize_initial_code() : active_story(string storyId, string desc) & active_revision(int rev) {
        console.println("[Developer] Synthesizing initial code candidate for story: '" + storyId + "' (Revision: " + rev + ")");
        !synthesize_code_with_guidelines(storyId, rev);
    }

    rule +!synthesize_code_with_guidelines(string storyId, int rev) 
            : active_story(storyId, string desc) & guidelines_context(string beliefContext) {
        
        console.println("[Developer] Invoking GRL with BDI Evolved Guidelines Context:\n  '" + beliefContext + "'");

        // Enforce structural schema verification AND inject our belief context as RAG context!
        string prompt = "Implement the following software requirement in Java. requirement:\n" + desc;
        string rid = gl.invoke_with_beliefs("developer", "synthesize_code", "llm.answer", "ANSWER", prompt, "code", beliefContext);
        !process_candidate(storyId, rid, rev);
    }

    rule +!process_candidate(string storyId, string rid, int rev) : gl.valid(rid) == true {
        string code = gl.field(rid, "code");
        string cid = gl.candidate(rid);
        
        console.println("[Developer] Candidate code generated successfully.");
        console.println("--------------------- CODE CANDIDATE ---------------------");
        console.println(code);
        console.println("----------------------------------------------------------");
        
        // Assert the code candidate AND the candidate ID into the belief base
        +candidate_code(storyId, code, rev, cid);
        
        // Send a FIPA propose message to the automated Tester agent B
        console.println("[Developer] Sending candidate to Tester B for automated compilation...");
        send(request, "tester", test_request(storyId, code, rev));
    }

    rule +!process_candidate(string storyId, string rid, int rev) : gl.valid(rid) == false {
        console.println("[Developer] GRL validation failed. Prompt response was malformed. Retrying...");
        !synthesize_initial_code();
    }

    // ── Reactive Peer Feedbacks ──────────────────────────────────

    // React to compilation/test failure from Tester B
    rule @message(inform, string sender, test_failure(string storyId, string errorLog, int rev))
            : candidate_code(storyId, string oldCode, rev, string cid) {
        console.println("[Developer] ❌ Tester B reported a compilation/test failure at Rev " + rev + ".");
        console.println("[Developer] Error logs: " + errorLog);

        // Reject the candidate locally in the GRL kernel using the stored cid
        gl.reject(cid);

        // Record the failure Trace in the BDI belief base
        +compilation_error(storyId, errorLog, rev);

        // Trigger belief revision ("re-thinking") first before generating refined code!
        !rethink_beliefs(storyId, oldCode, errorLog, rev);
    }

    // React to security violation from Auditor C
    rule @message(inform, string sender, security_violation_msg(string storyId, string vulnerability, int rev))
            : candidate_code(storyId, string oldCode, rev, string cid) {
        console.println("[Developer] ⚠️ Auditor C reported a security violation at Rev " + rev + ".");
        console.println("[Developer] Vulnerability: " + vulnerability);

        // Reject the candidate locally
        gl.reject(cid);

        // Record security violation belief
        +security_violation(storyId, vulnerability, rev);

        // Trigger belief revision ("re-thinking") to adapt to this security threat!
        !rethink_beliefs(storyId, oldCode, vulnerability, rev);
    }

    // React to final audit approval from Auditor C
    rule @message(inform, string sender, audit_approved(string storyId, string finalCode))
            : candidate_code(storyId, finalCode, int rev, string cid) {
        // Officially adopt candidate into BDI beliefs using stored cid
        gl.accept(cid);
        +completed_module(storyId, finalCode);

        console.println("");
        console.println("==================================================");
        console.println("🎉 SUCCESS! Software module '" + storyId + "' is fully resolved!");
        console.println("Final Codebase adopted: \n" + finalCode);
        console.println("==================================================");
        console.println("");

        // Broadcast to Tester B and Auditor C so they synchronize their belief bases
        console.println("[Developer] Broadcasting finalized module to all agents in the swarm...");
        send(inform, "tester", module_finalized(storyId, finalCode));
        send(inform, "auditor", module_finalized(storyId, finalCode));
    }

    // ── Self-Correcting / Self-Improving / Belief Revision Plans ───

    rule +!rethink_beliefs(string storyId, string oldCode, string errorLog, int rev) {
        console.println("[Developer] 🧠 Self-Developing: Analyzing mistake to formulate new architectural belief...");
        
        string prompt = "Analyze the compilation or logic error for this Java code:\n"
                      + "```java\n" + oldCode + "\n```\n\n"
                      + "Error log:\n"
                      + "```\n" + errorLog + "\n```\n\n"
                      + "Formulate a single general programming guideline (1-2 sentences) to prevent this class of errors from ever happening again. "
                      + "Set 'rule_name' to a short camelCase identifier and 'rule_description' to the guideline description.";

        string rid = gl.invoke("developer", "rethink", "llm.answer", "ANSWER", prompt, "rule_name,rule_description");
        !adopt_new_guideline(storyId, rid, rev);
    }

    rule +!adopt_new_guideline(string storyId, string rid, int rev) : gl.valid(rid) == true & guidelines_context(string prevContext) {
        string name = gl.field(rid, "rule_name");
        string desc = gl.field(rid, "rule_description");
        
        console.println("[Developer] 💡 Evolved new architectural belief: [" + name + "] -> " + desc);
        
        // Assert the new rule as a persistent domain belief for tracing
        +architectural_guideline(name, desc);
        
        // Dynamically update the RAG guidelines context belief!
        string newContext = prevContext + " | " + name + " -> " + desc;
        -+guidelines_context(newContext);
        
        // Proceed to generate refined code under our newly updated belief system!
        int nextRev = rev + 1;
        -+active_revision(nextRev);
        !synthesize_code_with_guidelines(storyId, nextRev);
    }

    rule +!adopt_new_guideline(string storyId, string rid, int rev) : gl.valid(rid) == false {
        console.println("[Developer] Failed to evolve new belief. Proceeding with standard correction.");
        int nextRev = rev + 1;
        -+active_revision(nextRev);
        !synthesize_code_with_guidelines(storyId, nextRev);
    }
}
