agent PatternRunner {
    module gl.adapter.astra.AstraAdapter gl;
    module Console console;

    types governance {
        formula primary_setting(string, string);
        formula verifier_setting(string, string);
        formula configured_primary(boolean);
        formula configured_verifier(boolean);
        formula verified(string);
        formula cross_checked(string);
        formula accepted(string);
        formula rejected(string);
    }

    initial primary_setting("model", "gemini-2.5-flash"), primary_setting("provider", "gemini");
    initial verifier_setting("model", "gpt-oss-120b"), verifier_setting("provider", "cerebras");

    inference verified(string rid) :- cross_checked(rid);
    inference verified(string rid) :- rejected(rid);

    rule +!main(list args) {
        !configured_primary(true);
        !classified("apple");
    }

    rule +!configured_primary(boolean x) : primary_setting("model", string m) & primary_setting("provider", string p) {
        gl.configure("model", m);
        gl.use_provider(p);
    }

    rule +!configured_verifier(boolean x) : verifier_setting("model", string m) & verifier_setting("provider", string p) {
        gl.configure("model", m);
        gl.use_provider(p);
    }

    rule +!classified(string item) {
        !verified(gl.ask("agent1", "classify", "Classify: " + item));
    }

    rule +!verified(string rid) : verified(rid) {
        console.println("Already verified: " + rid);
    }

    rule +!verified(string rid) : gl.valid(rid) == true {
        !cross_checked(rid, gl.field(rid, "label"));
        ?verified(rid);
    }

    rule +!verified(string rid) {
        gl.reject(gl.candidate(rid));
        +rejected(rid);
        console.println("Invalid first output - REJECTED");
    }

    rule +!cross_checked(string rid, string firstLabel) {
        !configured_verifier(true);
        !labels_match(rid, gl.ask("agent1", "verify", "Verify classification. Return label only. apple = " + firstLabel), firstLabel);
    }

    rule +!labels_match(string rid, string vrid, string firstLabel) : gl.field(vrid, "label") == firstLabel {
        gl.accept(gl.candidate(rid));
        gl.accept(gl.candidate(vrid));
        +accepted(rid);
        +cross_checked(rid);
        console.println("Providers agree on '" + firstLabel + "' - ACCEPTED");
    }

    rule +!labels_match(string rid, string vrid, string firstLabel) {
        gl.reject(gl.candidate(rid));
        gl.reject(gl.candidate(vrid));
        +rejected(rid);
        console.println("Providers disagree - REJECTED");
    }

    rule -!verified(string rid) {
        console.println("Verification FAILED for " + rid);
    }

    rule -!cross_checked(string rid, string firstLabel) {
        console.println("Cross-check FAILED for " + rid);
    }
}
