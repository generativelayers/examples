/**
 * Pattern 4: Cross-LLM Verification — ASTRA
 *
 * Asks a second LLM to verify the first LLM's output.
 * Uses try/recover for resilience, ~= for label comparison.
 * Demonstrates: constants, try/recover, ~= inequality, inference, query().
 */
agent PatternRunner {
    module gl.adapter.astra.AstraAdapter gl;
    module Console console;
    module System S;

    constant string MODEL = "gpt-oss-120b";
    constant string PROVIDER = "cerebras";

    types pattern_types {
        formula verified(boolean);
        formula attempt_count(int);
    }

    initial attempt_count(0);

    // Inference: verified is true when the belief exists
    inference verified(true) :- verified(true);

    rule +!main(list args) {
        console.println("=== Pattern 4: Cross-LLM Verification ===");
        gl.configure("model", MODEL);
        gl.use_provider(PROVIDER);

        // try/recover: resilient LLM call
        try {
            string rid = gl.ask("agent1", "classify", "Classify: apple");
            !verify(rid);
        } recover {
            console.println("First LLM call failed → try/recover caught it");
        }
    }

    // First LLM valid — send to second for verification
    rule +!verify(string rid) : gl.valid(rid) == true {
        string label = gl.field(rid, "label");
        string cid = gl.candidate(rid);
        console.println("First LLM says: " + label + " — cross-checking...");

        // Increment attempt counter using query() + -+
        query(attempt_count(int count));
        -+attempt_count(count + 1);

        // Second LLM call also wrapped in try/recover
        try {
            string vrid = gl.ask("agent1", "verify", "Is this correct? apple = " + label);
            string vlabel = gl.field(vrid, "label");
            !compare(cid, vrid, label, vlabel);
        } recover {
            console.println("Second LLM call failed → REJECTED");
            gl.reject(cid);
        }
    }

    // First LLM invalid — cannot proceed
    rule +!verify(string rid) {
        console.println("First LLM invalid → ABORTED");
    }

    // Both labels match — accept
    rule +!compare(string cid, string vrid, string l1, string l2) : l1 == l2 {
        gl.accept(cid);
        +verified(true);
        console.println("Labels match ('" + l1 + "' == '" + l2 + "') → ACCEPTED");
    }

    // Labels disagree — reject (uses ~= inequality operator)
    rule +!compare(string cid, string vrid, string l1, string l2) : l1 ~= l2 {
        gl.reject(cid);
        console.println("Labels DISAGREE ('" + l1 + "' ~= '" + l2 + "') → REJECTED");
    }
}
