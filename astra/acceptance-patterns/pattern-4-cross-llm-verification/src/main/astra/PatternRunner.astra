// Pipeline: main > !classified > !verified > !cross_check > !evaluate_verifier > !match_labels
// Pattern 4: Cross-LLM Verification - ASTRA
//
// Use a primary provider and a verifier provider; accept only
// when both candidates agree.
agent PatternRunner {
    module gl.astra.GL gl;
    module Console console;
    module System S;

    types governance {
        formula primary_binding(string);
        formula verifier_binding(string);
        formula verified(string);
        formula accepted(string);
        formula rejected(string);
    }

    inference verified(string cid) :- accepted(cid);
    inference verified(string cid) :- rejected(cid);

    rule +!main(list args) {
        !banner();
        +primary_binding(gl.bind("agent1", "groq", "llama-3.3-70b-versatile", ""));
        +verifier_binding(gl.bind("verifier1", "cerebras", "gpt-oss-120b", ""));
        !classified("apple");
        !shutdown();
    }

    // ACHIEVEMENT: clean exit
    rule +!shutdown() {
        S.exit();
    }

    // ACHIEVEMENT: display banner
    rule +!banner() {
        console.println("=== Pattern 4: Cross-LLM Verification ===");
        console.println("");
        console.println("[Layer] Available providers: " + gl.see());
    }

    // DECOMPOSITION: classify = call + inspect
    rule +!classified(string item) : primary_binding(string bid) & verifier_binding(string vbid) {
        !verified(gl.call(bid, "classify", "llm.answer", "ANSWER",
            "Classify: " + item + ". Return only a label field.", "label", ""), item, bid, vbid);
    }

    // SERENDIPITY: already verified
    rule +!verified(string rid, string item, string bid, string vbid) : verified(gl.candidate(rid)) {
        console.println("[AGENT] Already verified: " + rid);
    }

    // DECOMPOSITION: admissible > check verifier output
    rule +!verified(string rid, string item, string bid, string vbid) : gl.decide(gl.candidate(rid)) == "ADMISSIBLE" {
        !cross_check(rid, gl.candidate(rid), gl.get(gl.candidate(rid), "label"), item, bid, vbid);
    }

    // DECOMPOSITION: not admissible > reject
    rule +!verified(string rid, string item, string bid, string vbid) {
        !rejected_primary(gl.candidate(rid), rid);
    }

    // DECOMPOSITION: cross-check with verifier
    rule +!cross_check(string rid, string primaryCid, string primaryLabel, string item, string bid, string vbid) {
        !evaluate_verifier(rid, primaryCid, primaryLabel,
            gl.call(vbid, "verify", "llm.answer", "ANSWER",
                "Classify this item and return only a label field: " + item, "label", ""),
            item);
    }

    // DECOMPOSITION: verifier admissible > compare labels
    rule +!evaluate_verifier(string rid, string primaryCid, string primaryLabel, string vrid, string item) :
            gl.decide(gl.candidate(vrid)) == "ADMISSIBLE" {
        console.println("Primary Agent: label = " + primaryLabel);
        console.println("Verifier Agent: label = " + gl.get(gl.candidate(vrid), "label"));
        !match_labels(rid, primaryCid, primaryLabel, vrid, gl.candidate(vrid), gl.get(gl.candidate(vrid), "label"));
    }

    // DECOMPOSITION: verifier not admissible > reject
    rule +!evaluate_verifier(string rid, string primaryCid, string primaryLabel, string vrid, string item) {
        !rejected_verifier(primaryCid, gl.candidate(vrid), rid, vrid);
    }

    // ACHIEVEMENT: labels match > accept both
    rule +!match_labels(string rid, string primaryCid, string primaryLabel, string vrid, string verifierCid, string verifierLabel) : primaryLabel == verifierLabel {
        gl.accept(primaryCid, "cross-LLM match: " + primaryLabel);
        gl.accept(verifierCid, "cross-LLM match: " + verifierLabel);
        +accepted(primaryCid);
        +accepted(verifierCid);
        console.println("Result: MATCH - ACCEPTED");
        !print_trace(rid);
        !print_trace(vrid);
        console.println("=== Demo Complete ===");
    }

    // ACHIEVEMENT: labels mismatch > reject both
    rule +!match_labels(string rid, string primaryCid, string primaryLabel, string vrid, string verifierCid, string verifierLabel) {
        gl.reject(primaryCid, "cross-LLM mismatch: " + primaryLabel + " vs " + verifierLabel);
        gl.reject(verifierCid, "cross-LLM mismatch: " + primaryLabel + " vs " + verifierLabel);
        +rejected(primaryCid);
        +rejected(verifierCid);
        console.println("Result: MISMATCH - REJECTED");
        !print_trace(rid);
        !print_trace(vrid);
        console.println("=== Demo Complete ===");
    }

    // ACHIEVEMENT: reject primary only (actions only)
    rule +!rejected_primary(string cid, string rid) {
        gl.reject(cid, "primary validation failed");
        +rejected(cid);
        console.println("Invalid primary output - REJECTED");
        !print_trace(rid);
    }

    // ACHIEVEMENT: reject both due to verifier invalid (actions only)
    rule +!rejected_verifier(string primaryCid, string verifierCid, string rid, string vrid) {
        gl.reject(primaryCid, "verifier validation failed");
        gl.reject(verifierCid, "verifier validation failed");
        +rejected(primaryCid);
        +rejected(verifierCid);
        console.println("Verifier output invalid - REJECTED");
        !print_trace(rid);
        !print_trace(vrid);
    }

    // ACHIEVEMENT: print trace
    rule +!print_trace(string rid) {
        console.println("");
        console.println("[TRACE] " + gl.explain(rid));
    }

    // RECOVERY
    rule -!verified(string rid, string item, string bid, string vbid) : ~accepted(string _) & ~rejected(string _) {
        console.println("Verification FAILED for " + rid);
    }
}

// NOTE: To make verification deterministic, you can configure the temperature parameter.
// Pass "temperature=0.0" inside the configuration string (4th argument of the bind call):
//
// +primary_binding(gl.bind("agent1", "groq", "llama-3.3-70b-versatile", "temperature=0.0"));
// +verifier_binding(gl.bind("verifier1", "cerebras", "gpt-oss-120b", "temperature=0.0"));
//
// Temperature levels control model randomness:
// - High Temperature (0.8 to 1.2): Highly creative and random (good for brainstorming/stories).
// - Low Temperature (default 0.2): Focused and consistent, but minor variations can still occur.
// - Zero Temperature (0.0): Completely deterministic. The model will select the highest-probability
//   word at every step, guaranteeing the exact same output every run.

