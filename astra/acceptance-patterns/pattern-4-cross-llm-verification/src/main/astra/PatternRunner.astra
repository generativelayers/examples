/**
 * Pattern 4: Cross-LLM Verification — ASTRA
 *
 * Asks a second LLM to verify the first LLM's output.
 * Accepts only if both providers return valid results.
 */
agent PatternRunner {
    module gl.adapter.astra.AstraAdapter gl;
    module Console console;

    rule +!main(list args) {
        console.println("=== Pattern 4: Cross-LLM Verification ===");
        // gl.configure("model", "gemini-2.0-flash");
        // gl.use_provider("gemini");
        gl.configure("endpoint", "https://api.groq.com/openai/v1/chat/completions");
        gl.configure("model", "llama-3.3-70b-versatile");
        gl.configure("apiKeyEnv", "GROQ_API_KEY");
        gl.use_provider("openai");
        string rid = gl.ask("agent1", "classify", "Classify: apple");
        !verify(rid);
    }

    rule +!verify(string rid) : gl.valid(rid) == true {
        string label = gl.field(rid, "label");
        string cid = gl.candidate(rid);
        string vrid = gl.ask("agent1", "verify", "Is this correct? apple = " + label);
        !compare(cid, vrid);
    }

    rule +!compare(string cid, string vrid) : gl.valid(vrid) == true {
        gl.accept(cid);
        console.println("Both providers agreed → ACCEPTED");
    }

    rule +!compare(string cid, string vrid) : gl.valid(vrid) == false {
        gl.reject(cid);
        console.println("Second provider invalid → REJECTED");
    }
}
