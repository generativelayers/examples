// Pipeline: @message → +review_pending → !review_decided → send(approve|reject) → ?review_decided
agent Reviewer {
    module Console console;

    types review_types {
        formula review_request(string, string);
        formula review_approved(string);
        formula review_rejected(string, string);
        formula review_pending(string, string, string);
        formula review_decided(string);
        formula known_food(string);
    }

    initial known_food("fruit"), known_food("vegetable"), known_food("grain");

    // DOMAIN MODEL
    inference review_decided(string cid) :- review_approved(cid);

    // REACTIVE: incoming request → store as belief
    rule @message(request, string sender, review_request(string label, string cid)) {
        +review_pending(label, cid, sender);
    }

    // DELIBERATION: pending review → adopt decision goal
    rule +review_pending(string label, string cid, string sender) : ~review_decided(cid) {
        !review_decided(cid);
    }

    // SERENDIPITY
    rule +!review_decided(string cid) : review_decided(cid) {
        console.println("[Reviewer] Already decided for " + cid);
    }

    // ACHIEVEMENT: known → approve
    rule +!review_decided(string cid) : review_pending(string label, cid, string sender) & known_food(label) {
        send(inform, sender, review_approved(cid));
        +review_approved(cid);
        ?review_decided(cid);
        console.println("[Reviewer] '" + label + "' is known → APPROVED");
    }

    // ACHIEVEMENT: unknown → reject
    rule +!review_decided(string cid) : review_pending(string label, cid, string sender) & ~known_food(label) {
        send(inform, sender, review_rejected(cid, "not in knowledge base"));
        console.println("[Reviewer] '" + label + "' is unknown → DISAPPROVED");
    }

    // RECOVERY
    rule -!review_decided(string cid) {
        console.println("[Reviewer] Decision FAILED for " + cid);
    }
}
