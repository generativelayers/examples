/**
 * Pattern 5: Agent-to-Agent Review - Runner Agent
 *
 * Classifies an item, sends result to a Reviewer peer,
 * and waits for the peer's verdict via message passing.
 *
 * Principles used:
 *   - Decomposition Plans (start > configure > classify > review)
 *   - Means-End Reasoning (how to achieve review)
 *   - Reactive Plans      (handle incoming messages)
 *   - Recovery Plans      (handle failures)
 *   - Domain Modelling    (inference rules)
 */
agent PatternRunner {
    module gl.astra.GL gl;
    module Console console;
    module System S;

    types review_types {
        formula setting(string, string);
        formula reviewed(string);
        formula peer_approved(string);
        formula review_request(string, string);
        formula review_approved(string);
        formula review_rejected(string, string);
    }

    initial setting("model", "gpt-oss-120b"), setting("provider", "cerebras");

    // Sub-agents use initial !start() (not +!main)
    initial !start();

    // DOMAIN MODEL
    inference reviewed(string cid) :- peer_approved(cid);

    // DECOMPOSITION: start > configure > review
    rule +!start() {
        !configured(true);
        !reviewed(gl.invoke("agent1", "classify", "llm.answer", "CLASSIFY", "Classify: tomato. Return a label field.", "label"));
        !shutdown();
    }

    // ACHIEVEMENT: clean exit (actions only)
    rule +!shutdown() {
        S.exit();
    }

    // ACHIEVEMENT: configure provider
    rule +!configured(boolean x) :
            setting("model", string m) & setting("provider", string p) {
        gl.configure("model", m);
        gl.use_provider(p);
    }

    // SERENDIPITY: already reviewed
    rule +!reviewed(string rid) : reviewed(rid) {
        console.println("[Runner] Already reviewed: " + rid);
    }

    // MEANS-END: valid > send to reviewer and wait
    rule +!reviewed(string rid) : gl.valid(rid) == true {
        string label = gl.field(rid, "label");
        string cid = gl.candidate(rid);
        console.println("[Runner] Sending '" + label + "' to reviewer...");
        send(request, "reviewer", review_request(label, cid));
        // Wait for peer verdict via belief event (30s timeout)
        wait(peer_approved(cid), 30000);
    }

    // MEANS-END: invalid output > skip
    rule +!reviewed(string rid) {
        console.println("[Runner] Invalid output - SKIPPED");
    }

    // REACTIVE: peer approved > adopt belief and accept
    rule @message(inform, string sender, review_approved(string cid)) {
        +peer_approved(cid);
        gl.accept(cid);
        console.println("[Runner] Peer approved - ACCEPTED");
    }

    // REACTIVE: peer rejected > reject
    rule @message(inform, string sender, review_rejected(string cid, string reason)) {
        gl.reject(cid);
        console.println("[Runner] Peer rejected: " + reason + " - REJECTED");
    }

    // RECOVERY
    rule -!reviewed(string rid) : ~peer_approved(string _) {
        console.println("[Runner] Review FAILED for " + rid);
    }
}
