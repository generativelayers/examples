/**
 * Pattern 5: Agent-to-Agent Review — ASTRA (Runner)
 *
 * Generates LLM output, then sends the label to a peer reviewer
 * agent for approval via FIPA messaging.
 * Demonstrates: constants, FIPA messaging, practical reasoning.
 */
agent PatternRunner {
    module gl.adapter.astra.AstraAdapter gl;
    module Console console;

    constant string MODEL = "gpt-oss-120b";
    constant string PROVIDER = "cerebras";

    types review_types {
        formula review_request(string, string);
        formula review_approved(string);
        formula review_rejected(string, string);
    }

    initial !start();

    rule +!start() {
        gl.configure("model", MODEL);
        gl.use_provider(PROVIDER);
        string rid = gl.ask("agent1", "classify", "Classify: tomato");
        !request_review(rid);
    }

    // Valid output — send to peer reviewer
    rule +!request_review(string rid) : gl.valid(rid) == true {
        string label = gl.field(rid, "label");
        string cid = gl.candidate(rid);
        console.println("[Runner] Sending '" + label + "' to reviewer...");
        send(request, "reviewer", review_request(label, cid));
    }

    // Invalid output — skip
    rule +!request_review(string rid) {
        console.println("[Runner] Invalid output → SKIPPED");
    }

    // Peer approved — accept
    rule @message(inform, string sender, review_approved(string cid)) {
        gl.accept(cid);
        console.println("[Runner] Peer approved → ACCEPTED");
    }

    // Peer rejected — reject
    rule @message(inform, string sender, review_rejected(string cid, string reason)) {
        gl.reject(cid);
        console.println("[Runner] Peer rejected: " + reason + " → REJECTED");
    }
}
