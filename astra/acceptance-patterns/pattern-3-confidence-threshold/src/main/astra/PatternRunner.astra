agent PatternRunner {
    module gl.astra.GL gl;
    module Console console;

    types governance {
        formula setting(string, string);
        formula configured(boolean);
        formula assessed(string);
        formula accepted(string);
        formula rejected(string);
        formula escalated(string);
        formula confidence_tier(string, string);
    }

    initial setting("model", "gpt-oss-120b"), setting("provider", "cerebras");

    inference assessed(string rid) :- accepted(rid);
    inference assessed(string rid) :- rejected(rid);
    inference assessed(string rid) :- escalated(rid);

    rule +!main(list args) {
        !configured(true);
        !classified("apple");
    }

    rule +!configured(boolean x) : setting("model", string m) & setting("provider", string p) {
        gl.configure("model", m);
        gl.use_provider(p);
    }

    rule +!classified(string item) {
        !assessed(gl.invoke("agent1", "classify", "llm.answer", "ANSWER", "Classify: " + item + ". Return label and confidence_tier: high, medium, or low.", "label,confidence_tier"));
    }

    rule +!assessed(string rid) : assessed(rid) {
        console.println("Already assessed: " + rid);
    }

    rule +!assessed(string rid) : gl.valid(rid) == true {
        !assess_confidence(rid, gl.candidate(rid), gl.field(rid, "confidence_tier"));
    }

    rule +!assessed(string rid) {
        gl.reject(gl.candidate(rid));
        +rejected(rid);
        console.println("Invalid output - REJECTED");
    }

    rule +!assess_confidence(string rid, string cid, string tier) : tier == "high" {
        gl.accept(cid);
        +accepted(rid);
        +confidence_tier(rid, "high");
        ?assessed(rid);
        console.println("High confidence - ACCEPTED");
    }

    rule +!assess_confidence(string rid, string cid, string tier) : tier == "low" {
        gl.reject(cid);
        +rejected(rid);
        +confidence_tier(rid, "low");
        ?assessed(rid);
        console.println("Low confidence - REJECTED");
    }

    rule +!assess_confidence(string rid, string cid, string tier) {
        +escalated(rid);
        +confidence_tier(rid, tier);
        ?assessed(rid);
        console.println("Confidence tier " + tier + " - ESCALATING");
    }

    rule -!assessed(string rid) {
        console.println("Assessment FAILED for " + rid);
    }
}
