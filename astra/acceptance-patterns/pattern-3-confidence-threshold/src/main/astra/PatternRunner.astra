/**
 * Pattern 3: Confidence Threshold — ASTRA
 *
 * Extracts the confidence field and makes a tiered decision:
 * high (1.0) → accept, low (0.0) → reject, otherwise → escalate.
 * Demonstrates: constants, query() in rule bodies, practical reasoning.
 */
agent PatternRunner {
    module gl.adapter.astra.AstraAdapter gl;
    module Console console;

    constant string MODEL = "gpt-oss-120b";
    constant string PROVIDER = "cerebras";
    constant string HIGH_CONFIDENCE = "1.0";
    constant string LOW_CONFIDENCE = "0.0";

    types pattern_types {
        formula confidence_tier(string);
        formula last_confidence(string);
    }

    rule +!main(list args) {
        console.println("=== Pattern 3: Confidence Threshold ===");
        gl.configure("model", MODEL);
        gl.use_provider(PROVIDER);
        string rid = gl.invoke(
            "agent1",
            "classify",
            "llm.answer",
            "ANSWER",
            "Classify: apple",
            "label,confidence"
        );
        !decide(rid);
    }

    rule +!decide(string rid) : gl.valid(rid) == true {
        string cid = gl.candidate(rid);
        string conf = gl.field(rid, "confidence");
        +last_confidence(conf);
        !assess(cid, conf);
    }

    rule +!decide(string rid) {
        console.println("Invalid output → REJECTED");
    }

    // High confidence — accept immediately
    rule +!assess(string cid, string conf) : conf == HIGH_CONFIDENCE {
        gl.accept(cid);
        -+confidence_tier("high");
        console.println("High confidence (" + HIGH_CONFIDENCE + ") → ACCEPTED");
    }

    // Low confidence — reject
    rule +!assess(string cid, string conf) : conf == LOW_CONFIDENCE {
        gl.reject(cid);
        -+confidence_tier("low");
        console.println("Low confidence (" + LOW_CONFIDENCE + ") → REJECTED");
    }

    // Medium confidence — escalate (catch-all), use query() to confirm tier
    rule +!assess(string cid, string conf) {
        -+confidence_tier("medium");
        query(confidence_tier(string tier));
        console.println("Confidence tier: " + tier + " (" + conf + ") → ESCALATING");
    }
}
