// Pipeline: main > !classified > !assessed > !assess_confidence
// Pattern 3: Confidence Tier - ASTRA
//
// Use a categorical confidence tier: high accepts, low rejects,
// and medium/unknown escalates.
agent PatternRunner {
    module gl.astra.GL gl;
    module Console console;
    module System S;

    types governance {
        formula binding(string);
        formula assessed(string);
        formula accepted(string);
        formula rejected(string);
        formula escalated(string);
        formula confidence_tier(string, string);
    }

    inference assessed(string cid) :- accepted(cid);
    inference assessed(string cid) :- rejected(cid);
    inference assessed(string cid) :- escalated(cid);

    rule +!main(list args) {
        !banner();
        +binding(gl.bind("agent1", "groq", "llama-3.3-70b-versatile", ""));
        !classified("apple");
        !shutdown();
    }

    // ACHIEVEMENT: clean exit
    rule +!shutdown() {
        S.exit();
    }

    // ACHIEVEMENT: display banner
    rule +!banner() {
        console.println("=== Pattern 3: Confidence Tier ===");
        console.println("");
        console.println("[Layer] Available providers: " + gl.see());
    }

    // DECOMPOSITION: classify = call + deliberate/assess
    rule +!classified(string item) : binding(string bid) {
        !assessed(gl.call(bid, "classify", "llm.answer", "ANSWER",
            "Classify: " + item + ". Return label and confidence_tier: high, medium, or low.",
            "label,confidence_tier", ""));
    }

    // SERENDIPITY: already assessed
    rule +!assessed(string rid) : assessed(gl.candidate(rid)) {
        console.println("[AGENT] Already assessed: " + rid);
    }

    // DECOMPOSITION: admissible > check confidence tier
    rule +!assessed(string rid) : gl.decide(gl.candidate(rid)) == "ADMISSIBLE" {
        !assess_confidence(rid, gl.candidate(rid), gl.get(gl.candidate(rid), "confidence_tier"));
        !print_trace(rid);
    }

    // DECOMPOSITION: not admissible > reject
    rule +!assessed(string rid) {
        !rejected_candidate(gl.candidate(rid), rid);
        !print_trace(rid);
    }

    // ACHIEVEMENT: high confidence > accept
    rule +!assess_confidence(string rid, string cid, string tier) : tier == "high" {
        gl.accept(cid, "high confidence");
        +accepted(cid);
        +confidence_tier(cid, "high");
        console.println("High confidence - ACCEPTED");
        console.println("  label = " + gl.get(cid, "label"));
        console.println("=== Demo Complete ===");
    }

    // ACHIEVEMENT: low confidence > reject
    rule +!assess_confidence(string rid, string cid, string tier) : tier == "low" {
        gl.reject(cid, "low confidence");
        +rejected(cid);
        +confidence_tier(cid, "low");
        console.println("Low confidence - REJECTED");
        console.println("=== Demo Complete ===");
    }

    // ACHIEVEMENT: medium/other > escalate
    rule +!assess_confidence(string rid, string cid, string tier) {
        +escalated(cid);
        +confidence_tier(cid, tier);
        console.println("Confidence tier '" + tier + "' - ESCALATING");
        console.println("=== Demo Complete ===");
    }

    // ACHIEVEMENT: reject (actions only)
    rule +!rejected_candidate(string cid, string rid) {
        gl.reject(cid, "failed validation");
        +rejected(cid);
        console.println("Invalid output - REJECTED");
    }

    // ACHIEVEMENT: print trace
    rule +!print_trace(string rid) {
        console.println("");
        console.println("[TRACE] " + gl.explain(rid));
    }

    // RECOVERY
    rule -!assessed(string rid) : ~accepted(string _) & ~rejected(string _) & ~escalated(string _) {
        console.println("Assessment FAILED for " + rid);
    }
}
