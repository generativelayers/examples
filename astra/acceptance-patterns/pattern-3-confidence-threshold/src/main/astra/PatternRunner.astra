agent PatternRunner {
    module gl.adapter.astra.AstraAdapter gl;
    module Console console;
    module System S;

    types governance {
        formula setting(string, string);
        formula configured(boolean);
        formula assessed(string);
        formula accepted(string);
        formula rejected(string);
        formula escalated(string);
        formula confidence_tier(string, string);
    }

    initial setting("model", "gpt-oss-120b"), setting("provider", "cerebras");

    inference assessed(string rid) :- accepted(rid);
    inference assessed(string rid) :- rejected(rid);
    inference assessed(string rid) :- escalated(rid);

    rule +!main(list args) {
        !configured(true);
        !assessed(gl.invoke("agent1", "classify", "llm.answer", "ANSWER",