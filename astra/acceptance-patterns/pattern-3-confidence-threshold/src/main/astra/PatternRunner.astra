/**
 * Pattern 3: Confidence Threshold — ASTRA
 *
 * Extracts the confidence field and makes a tiered decision:
 * high → accept, low → reject with S.fail(), otherwise → escalate.
 * Demonstrates: beliefs as configuration, query(), -+, S.fail(), inference,
 * context-driven binding (no constants or imperative assignments).
 */
agent PatternRunner {
    module gl.adapter.astra.AstraAdapter gl;
    module Console console;
    module System S;

    types pattern_types {
        formula setting(string, string);
        formula threshold(string, string);
        formula confidence_tier(string);
        formula last_confidence(string);
        formula is_high_confidence(boolean);
    }

    // Configuration as beliefs (can be updated at runtime, queried in contexts)
    initial setting("model", "gpt-oss-120b"), setting("provider", "cerebras");
    initial threshold("high", "1.0"), threshold("low", "0.0");

    // Inference: derive whether we have high confidence
    inference is_high_confidence(true) :- confidence_tier("high");

    rule +!main(list args) : setting("model", string model) & setting("provider", string provider) {
        console.println("=== Pattern 3: Confidence Threshold ===");
        gl.configure("model", model);
        gl.use_provider(provider);
        !classify_and_decide("Classify: apple");
    }

    rule +!classify_and_decide(string prompt) {
        string rid = gl.invoke("agent1", "classify", "llm.answer", "ANSWER", prompt, "label,confidence");
        !decide(rid);
    }

    rule +!decide(string rid) : gl.valid(rid) == true {
        +last_confidence(gl.field(rid, "confidence"));
        !assess(gl.candidate(rid), gl.field(rid, "confidence"));
    }

    rule +!decide(string rid) {
        console.println("Invalid output → REJECTED");
    }

    // High confidence — accept (threshold bound from belief, not constant)
    rule +!assess(string cid, string conf) : threshold("high", conf) {
        gl.accept(cid);
        -+confidence_tier("high");
        query(threshold("high", string t));
        console.println("High confidence (" + t + ") → ACCEPTED");
    }

    // Low confidence — reject and fail the plan
    rule +!assess(string cid, string conf) : threshold("low", conf) {
        gl.reject(cid);
        -+confidence_tier("low");
        console.println("Low confidence → REJECTED");
        S.fail();
    }

    // Medium confidence — escalate (catch-all)
    rule +!assess(string cid, string conf) {
        -+confidence_tier("medium");
        query(confidence_tier(string tier));
        console.println("Confidence tier: " + tier + " (" + conf + ") → ESCALATING");
    }

    // Goal failure handler — catches S.fail() from low confidence
    rule -!assess(string cid, string conf) {
        console.println("Assessment FAILED for confidence: " + conf + " — plan aborted");
    }
}
