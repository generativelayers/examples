/**
 * Pattern 7: Majority Voting
 *
 * Three LLM calls independently classify the same input.
 * If at least two agree on the label, consensus is reached.
 *
 * Principles used:
 *   - Deliberation Plans  (main → goal adoption)
 *   - Means-End Reasoning (how to achieve each goal)
 *   - Decomposition Plans (goal → subgoals only)
 *   - Serendipity Plans   (goal already satisfied)
 *   - Domain Modelling    (inference rules for consensus)
 */
agent PatternRunner {
    module gl.astra.GL gl;
    module Console console;
    module astra.lang.System S;

    types governance {
        formula vote(int, string, string, string);
        formula consensus_label(string);
        formula consensus_reached(boolean);
    }

    // DOMAIN MODEL
    inference consensus_reached(true) :- consensus_label(string _);

    // ── DECOMPOSITION: main → cast 3 votes → check consensus ──
    rule +!main(list args) {
        // Vote 1: Gemini
        gl.configure("model", "gpt-oss-120b");
        gl.use_provider("cerebras");
        !vote_cast(1);
        // Vote 2: Cerebras
        gl.configure("model", "gpt-oss-120b");
        gl.use_provider("cerebras");
        !vote_cast(2);
        // Vote 3: Gemini again
        gl.configure("model", "gpt-oss-120b");
        gl.use_provider("cerebras");
        !vote_cast(3);
        // Tally
        !consensus_reached(true);
        S.exit();
    }

    // ── ACHIEVEMENT: cast a vote, store result + candidate ──
    rule +!vote_cast(int id) {
        string rid = gl.ask("agent1", "classify", "Classify: tomato. Return label field.");
        string cid = gl.candidate(rid);
        string label = gl.field(rid, "label");
        +vote(id, rid, cid, label);
        console.println("[Vote " + id + "] label = " + label);
    }

    // ── SERENDIPITY: already have consensus ──
    rule +!consensus_reached(boolean x) : consensus_reached(true) &
            consensus_label(string winner) {
        console.println("Already have consensus: " + winner);
    }

    // ── MEANS-END: tally the 3 votes ──
    rule +!consensus_reached(boolean x) :
            vote(1, string r1, string c1, string l1) &
            vote(2, string r2, string c2, string l2) &
            vote(3, string r3, string c3, string l3) {
        if (l1 == l2) {
            gl.accept(c1);
            gl.accept(c2);
            +consensus_label(l1);
            console.println("Majority (votes 1 & 2): '" + l1 + "' → ACCEPTED");
        } else if (l1 == l3) {
            gl.accept(c1);
            gl.accept(c3);
            +consensus_label(l1);
            console.println("Majority (votes 1 & 3): '" + l1 + "' → ACCEPTED");
        } else if (l2 == l3) {
            gl.accept(c2);
            gl.accept(c3);
            +consensus_label(l2);
            console.println("Majority (votes 2 & 3): '" + l2 + "' → ACCEPTED");
        } else {
            console.println("No majority → NO CONSENSUS");
        }
    }

    // ── RECOVERY ──
    rule -!consensus_reached(boolean x) {
        console.println("Consensus FAILED");
    }

    rule -!vote_cast(int id) {
        console.println("Vote " + id + " FAILED");
    }
}
