agent PatternRunner {
    module gl.adapter.astra.AstraAdapter gl;
    module Console console;

    types governance {
        formula vote(int, string, string);
        formula consensus_label(string);
        formula consensus_reached(boolean);
    }

    inference consensus_reached(true) :- consensus_label(string _);

    rule +!main(list args) {
        gl.configure("model", "gemini-2.5-flash");
        gl.use_provider("gemini");
        !vote_cast(1);
        gl.configure("model", "gpt-oss-120b");
        gl.use_provider("cerebras");
        !vote_cast(2);
        gl.configure("model", "gemini-2.5-flash");
        gl.use_provider("gemini");
        !vote_cast(3);
        !consensus_reached(true);
    }

    rule +!vote_cast(int id) {
        string rid = gl.ask("agent1", "classify", "Classify: tomato");
        +vote(id, gl.candidate(rid), gl.field(rid, "label"));
    }

    rule +!consensus_reached(boolean x) : consensus_reached(true) {
        query(consensus_label(string winner));
        console.println("Already have consensus: " + winner);
    }

    rule +!consensus_reached(boolean x) : vote(1, string c1, string l1) & vote(2, string c2, string l2) & vote(3, string c3, string l3) {
        !tallied(c1, l1, c2, l2, c3, l3);
        ?consensus_reached(true);
    }

    rule +!tallied(string c1, string l, string c2, string l, string c3, string l3) {
        gl.accept(c1);
        gl.accept(c2);
        +consensus_label(l);
        console.println("Majority 1 and 2 - ACCEPTED");
    }

    rule +!tallied(string c1, string l, string c2, string l2, string c3, string l) {
        gl.accept(c1);
        gl.accept(c3);
        +consensus_label(l);
        console.println("Majority 1 and 3 - ACCEPTED");
    }

    rule +!tallied(string c1, string l1, string c2, string l, string c3, string l) {
        gl.accept(c2);
        gl.accept(c3);
        +consensus_label(l);
        console.println("Majority 2 and 3 - ACCEPTED");
    }

    rule +!tallied(string c1, string l1, string c2, string l2, string c3, string l3) {
        console.println("No consensus - NO DECISION");
    }
}
