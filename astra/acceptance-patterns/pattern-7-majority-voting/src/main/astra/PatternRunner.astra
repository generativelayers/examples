/**
 * Pattern 7: Majority Voting — ASTRA
 *
 * Asks 3 providers the same question. Stores votes as beliefs,
 * then uses foreach to count matches and determine consensus.
 * Demonstrates: inference, query(), -+, foreach, ~= inequality,
 * beliefs as configuration, practical reasoning.
 */
agent PatternRunner {
    module gl.adapter.astra.AstraAdapter gl;
    module Console console;

    types pattern_types {
        formula setting(string, string);
        formula required_votes(int);
        formula vote(int, string);
        formula vote_count(int);
        formula consensus_label(string);
        formula has_consensus(boolean);
    }

    initial setting("model", "gpt-oss-120b"), setting("provider", "cerebras");
    initial required_votes(2);
    initial vote_count(0);

    // Inference: consensus reached when we have a consensus_label
    inference has_consensus(true) :- consensus_label(string _);

    rule +!main(list args) : setting("model", string model) & setting("provider", string provider) {
        console.println("=== Pattern 7: Majority Voting ===");
        gl.configure("model", model);
        gl.use_provider(provider);

        // Collect votes — store as beliefs directly
        +vote(1, gl.field(gl.ask("agent1", "classify", "Classify: tomato"), "label"));
        +vote(2, gl.field(gl.ask("agent1", "classify", "Classify: tomato"), "label"));
        +vote(3, gl.field(gl.ask("agent1", "classify", "Classify: tomato"), "label"));

        // Print all votes using foreach over beliefs
        foreach(vote(int id, string label)) {
            console.println("  Vote " + id + ": " + label);
        }

        // Extract labels for comparison via query()
        query(vote(1, string l1));
        query(vote(2, string l2));
        query(vote(3, string l3));

        !tally(l1, l2, l3);
    }

    // Providers 1 & 2 agree (specific rule first)
    rule +!tally(string l1, string l2, string l3) : l1 == l2 {
        +consensus_label(l1);
        -+vote_count(2);
        console.println("Majority agrees on '" + l1 + "' (1&2) → ACCEPTED");
    }

    // Providers 1 & 3 agree
    rule +!tally(string l1, string l2, string l3) : l1 == l3 {
        +consensus_label(l1);
        -+vote_count(2);
        console.println("Majority agrees on '" + l1 + "' (1&3) → ACCEPTED");
    }

    // Providers 2 & 3 agree — but 1 disagrees (uses ~= inequality)
    rule +!tally(string l1, string l2, string l3) : l2 == l3 & l1 ~= l2 {
        +consensus_label(l2);
        -+vote_count(2);
        console.println("Majority agrees on '" + l2 + "' (2&3, 1 disagrees) → ACCEPTED");
    }

    // No consensus — all disagree (catch-all)
    rule +!tally(string l1, string l2, string l3) {
        query(vote_count(int count));
        console.println("No consensus — all disagree (votes: " + count + ") → NO DECISION");
    }
}
