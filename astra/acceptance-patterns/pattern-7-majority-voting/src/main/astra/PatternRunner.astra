/**
 * Pattern 7: Majority Voting — ASTRA
 *
 * Asks 3 providers the same question. Compares labels pairwise.
 * Accepts only if 2+ providers agree on the same label.
 * Demonstrates: constants, inference, query(), -+ atomic replace,
 * practical reasoning for pairwise comparison.
 */
agent PatternRunner {
    module gl.adapter.astra.AstraAdapter gl;
    module Console console;

    constant string MODEL = "gpt-oss-120b";
    constant string PROVIDER = "cerebras";
    constant int REQUIRED_VOTES = 2;

    types pattern_types {
        formula vote_count(int);
        formula consensus_label(string);
        formula has_consensus(boolean);
    }

    initial vote_count(0);

    // Inference: consensus reached when we have a consensus_label
    inference has_consensus(true) :- consensus_label(string _);

    rule +!main(list args) {
        console.println("=== Pattern 7: Majority Voting ===");
        gl.configure("model", MODEL);
        gl.use_provider(PROVIDER);
        string r1 = gl.ask("agent1", "classify", "Classify: tomato");
        string r2 = gl.ask("agent1", "classify", "Classify: tomato");
        string r3 = gl.ask("agent1", "classify", "Classify: tomato");
        string l1 = gl.field(r1, "label");
        string l2 = gl.field(r2, "label");
        string l3 = gl.field(r3, "label");
        console.println("Provider 1: " + l1 + " | Provider 2: " + l2 + " | Provider 3: " + l3);
        !vote(r1, l1, r2, l2, r3, l3);
    }

    // Providers 1 & 2 agree (specific rule first)
    rule +!vote(string r1, string l1, string r2, string l2, string r3, string l3) : l1 == l2 {
        string cid = gl.candidate(r1);
        gl.accept(cid);
        +consensus_label(l1);
        query(vote_count(int count));
        -+vote_count(count + 2);
        console.println("Majority agrees on '" + l1 + "' (1&2) → ACCEPTED");
    }

    // Providers 1 & 3 agree
    rule +!vote(string r1, string l1, string r2, string l2, string r3, string l3) : l1 == l3 {
        string cid = gl.candidate(r1);
        gl.accept(cid);
        +consensus_label(l1);
        query(vote_count(int count));
        -+vote_count(count + 2);
        console.println("Majority agrees on '" + l1 + "' (1&3) → ACCEPTED");
    }

    // Providers 2 & 3 agree
    rule +!vote(string r1, string l1, string r2, string l2, string r3, string l3) : l2 == l3 {
        string cid = gl.candidate(r2);
        gl.accept(cid);
        +consensus_label(l2);
        query(vote_count(int count));
        -+vote_count(count + 2);
        console.println("Majority agrees on '" + l2 + "' (2&3) → ACCEPTED");
    }

    // No consensus — all disagree (catch-all)
    rule +!vote(string r1, string l1, string r2, string l2, string r3, string l3) {
        query(vote_count(int count));
        console.println("No consensus — all disagree (votes: " + count + ") → NO DECISION");
    }
}
