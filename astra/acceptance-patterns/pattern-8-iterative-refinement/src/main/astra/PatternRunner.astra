/**
 * Pattern 8: Iterative Refinement — Practical Reasoning Style
 *
 * Three-step pipeline: Draft → Critique → Refine → Accept.
 *
 * Collier Principles demonstrated:
 *   P1 Deliberation:    +draft_ready(rid) → !refined(rid)
 *   P2 Means-End:       +!refined(rid) → pipeline → ?refined(rid)
 *   P2 Serendipity:     +!refined(rid) : refined(rid) → done
 *   P4 Decomposition:   !refined decomposes to !critiqued, !improved
 *   P5 Recovery:        -!refined, -!critiqued, -!improved → log
 *   P7 Domain Model:    inference refined :- pipeline_step("accepted")
 *   Also: -+ atomic, belief-driven pipeline state
 */
agent PatternRunner {
    module gl.adapter.astra.AstraAdapter gl;
    module Console console;

    types governance {
        formula setting(string, string);
        formula draft_ready(string);
        formula refined(string);
        formula critiqued(string);
        formula improved(string);
        formula pipeline_step(string);
    }

    initial setting("model", "gpt-oss-120b"), setting("provider", "cerebras");

    // DOMAIN MODEL (Principle 7)
    inference refined(string rid) :- pipeline_step("accepted");

    // INITIAL: generate draft, store as belief
    rule +!main(list args) : setting("model", string m) & setting("provider", string p) {
        console.println("=== Pattern 8: Iterative Refinement ===");
        gl.configure("model", m);
        gl.use_provider(p);
        +pipeline_step("drafting");
        +draft_ready(gl.ask("agent1", "draft", "Write a 3-sentence summary of photosynthesis"));
    }

    // DELIBERATION (Principle 1) — draft ready, needs refinement
    rule +draft_ready(string rid) : gl.valid(rid) == true & ~refined(rid) {
        !refined(rid);
    }

    // REACTIVE (Principle 6) — invalid draft
    rule +draft_ready(string rid) : gl.valid(rid) ~= true {
        -+pipeline_step("draft_failed");
        console.println("Draft invalid → ABORTED");
    }

    // SERENDIPITY (Principle 2) — already refined
    rule +!refined(string rid) : refined(rid) {
        console.println("Already refined: " + rid);
    }

    // DECOMPOSITION (Principle 4) — refine = critique + improve + accept
    rule +!refined(string rid) : gl.valid(rid) == true {
        !critiqued(rid);
        !improved(rid);
        !accepted_final(rid);
        ?refined(rid);
    }

    // ACHIEVEMENT: critique the draft (Principle 2)
    rule +!critiqued(string draftRid) : gl.valid(draftRid) == true {
        -+pipeline_step("critiquing");
        console.println("Draft generated (valid) → requesting critique");
        +critiqued(gl.ask("agent1", "critique", "Critique the summary of photosynthesis"));
    }

    // SERENDIPITY
    rule +!critiqued(string rid) : critiqued(rid) {
        console.println("Already critiqued");
    }

    // ACHIEVEMENT: improve based on critique (Principle 2)
    rule +!improved(string rid) : critiqued(string critiqueRid) & gl.valid(critiqueRid) == true {
        -+pipeline_step("refining");
        console.println("Critique received (valid) → refining");
        +improved(gl.ask("agent1", "refine", "Improve the summary based on feedback"));
    }

    // SERENDIPITY
    rule +!improved(string rid) : improved(rid) {
        console.println("Already improved");
    }

    // ACHIEVEMENT: accept the final version (Principle 2)
    rule +!accepted_final(string rid) : improved(string finalRid) & gl.valid(finalRid) == true {
        gl.accept(gl.candidate(finalRid));
        -+pipeline_step("accepted");
        console.println("Draft → Critique → Refine pipeline complete → ACCEPTED");
    }

    // RECOVERY (Principle 5) — at each level
    rule -!refined(string rid) {
        -+pipeline_step("failed");
        console.println("Refinement pipeline FAILED for " + rid);
    }

    rule -!critiqued(string rid) {
        -+pipeline_step("critique_failed");
        console.println("Critique FAILED → pipeline aborted");
    }

    rule -!improved(string rid) {
        -+pipeline_step("refine_failed");
        console.println("Refinement FAILED → pipeline aborted");
    }
}
