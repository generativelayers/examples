// Pipeline: main > !drafted > !checked > !revised > !accepted_final
/**
 * Pattern 8: Iterative Refinement - ASTRA
 *
 * Generate, check, refine, and accept only the final validated
 * candidate. Free-text outputs use the framework's text field.
 */
agent PatternRunner {
    module gl.astra.GL gl;
    module Console console;
    module System S;

    types governance {
        formula binding(string);
        formula refined(string);
    }

    // DECOMPOSITION: main -> setup -> draft
    rule +!main(list args) {
        !banner();
        +binding(gl.bind("agent1", "groq", "llama-3.3-70b-versatile", ""));
        !drafted("Write a short paragraph about photosynthesis.");
        !shutdown();
    }

    // ACHIEVEMENT: clean exit
    rule +!shutdown() {
        S.exit();
    }

    // ACHIEVEMENT: display banner
    rule +!banner() {
        console.println("=== Pattern 8: Iterative Refinement ===");
        console.println("");
        console.println("[Layer] Available providers: " + gl.see());
    }

    // DECOMPOSITION: start draft
    rule +!drafted(string prompt) : binding(string bid) {
        !checked(gl.call(bid, "draft", "llm.answer", "ANSWER", prompt, "answer", ""));
    }

    // DECOMPOSITION: check draft
    rule +!checked(string draftRid) : binding(string bid) {
        !print_draft(draftRid);
        !revised(draftRid, gl.call(bid, "check", "llm.answer", "ANSWER",
            "Review this text and suggest improvements: " + gl.get(gl.candidate(draftRid), "answer"), "answer", ""));
    }

    // ACHIEVEMENT: print draft
    rule +!print_draft(string draftRid) {
        console.println("[Draft] " + gl.get(gl.candidate(draftRid), "answer"));
    }

    // DECOMPOSITION: revise draft
    rule +!revised(string draftRid, string checkRid) : binding(string bid) {
        !print_check(checkRid);
        !accepted_final(gl.call(bid, "revise", "llm.answer", "ANSWER",
            "Revise this text: " + gl.get(gl.candidate(draftRid), "answer") + " Based on: " + gl.get(gl.candidate(checkRid), "answer"), "answer", ""));
    }

    // ACHIEVEMENT: print check
    rule +!print_check(string checkRid) {
        console.println("[Check] " + gl.get(gl.candidate(checkRid), "answer"));
    }

    // DECOMPOSITION: accept final and print trace
    rule +!accepted_final(string finalRid) {
        !print_revised(finalRid);
        !accept_candidate(gl.candidate(finalRid), finalRid);
        !print_trace(finalRid);
        !print_complete();
    }

    // ACHIEVEMENT: print revised
    rule +!print_revised(string finalRid) {
        console.println("[Revised] " + gl.get(gl.candidate(finalRid), "answer"));
    }

    // ACHIEVEMENT: accept candidate
    rule +!accept_candidate(string cid, string finalRid) {
        gl.accept(cid, "final refined text");
        +refined(finalRid);
        console.println("Final candidate - ACCEPTED");
    }

    // ACHIEVEMENT: print trace
    rule +!print_trace(string rid) {
        console.println("");
        console.println("[TRACE] " + gl.explain(rid));
    }

    // ACHIEVEMENT: print complete
    rule +!print_complete() {
        console.println("=== Demo Complete ===");
    }

    // RECOVERY
    rule -!drafted(string prompt) : ~refined(string _) {
        console.println("Pipeline FAILED");
    }
}
