agent PatternRunner {
    module gl.adapter.astra.AstraAdapter gl;
    module Console console;

    types governance {
        formula setting(string, string);
        formula refined(string);
        formula checked(string);
        formula check_for(string, string);
        formula updated(string);
        formula accepted_final(boolean);
    }

    initial setting("model", "gpt-oss-120b"), setting("provider", "cerebras");

    inference refined(string rid) :- accepted_final(true);

    rule +!main(list args) {
        gl.configure("model", "gpt-oss-120b");
        gl.use_provider("cerebras");
        !refined(gl.ask("agent1", "step1", "Write short text about photosynthesis"));
    }

    rule +!refined(string rid) : refined(rid) {
        console.println("Already done: " + rid);
    }

    rule +!refined(string draftRid) : gl.valid(draftRid) == true {
        !checked(draftRid);
        !updated(draftRid);
        !accepted_final(draftRid);
        ?refined(draftRid);
    }

    rule +!refined(string draftRid) {
        gl.reject(gl.candidate(draftRid));
        console.println("First output invalid - REJECTED");
    }

    rule +!checked(string draftRid) : gl.valid(draftRid) == true {
        +check_for(draftRid, gl.ask("agent1", "step2", "Check text: " + gl.field(draftRid, "answer")));
    }

    rule +!updated(string draftRid) : check_for(draftRid, string checkRid) & gl.valid(checkRid) == true {
        +updated(gl.ask("agent1", "step3", "Text: " + gl.field(draftRid, "answer") + " Notes: " + gl.field(checkRid, "answer")));
    }

    rule +!updated(string rid) : updated(rid) {
        console.println("Already updated");
    }

    rule +!accepted_final(string rid) : updated(string finalRid) & gl.valid(finalRid) == true {
        gl.accept(gl.candidate(finalRid));
        +accepted_final(true);
        console.println("Final candidate ACCEPTED");
    }

    rule -!refined(string rid) {
        console.println("Pipeline failed: " + rid);
    }
}
