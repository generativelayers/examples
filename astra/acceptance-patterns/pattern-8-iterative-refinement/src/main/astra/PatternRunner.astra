// Pipeline: main > !configured > !refined > !checked > !updated > !accepted_final
/**
 * Pattern 8: Iterative Refinement - ASTRA
 *
 * Generate, check, refine, and accept only the final validated
 * candidate. Free-text outputs use the framework's text field.
 */
agent PatternRunner {
    module gl.astra.GL gl;
    module Console console;
    module System S;

    types governance {
        formula setting(string, string);
        formula refined(string);
        formula draft_text(string, string);
        formula check_notes(string, string);
    }

    initial setting("model", "gpt-oss-120b"), setting("provider", "cerebras");

    // "" DECOMPOSITION: main ' configure ' refine ""
    rule +!main(list args) {
        !configured(true);
        !refined(gl.ask("agent1", "step1",
            "Write a short paragraph about photosynthesis."));
        !shutdown();
    }

    // ACHIEVEMENT: clean exit (actions only)
    rule +!shutdown() {
        S.exit();
    }

    // "" ACHIEVEMENT: configure provider ""
    rule +!configured(boolean x) :
            setting("model", string m) & setting("provider", string p) {
        gl.configure("model", m);
        gl.use_provider(p);
    }

    // "" SERENDIPITY: already refined ""
    rule +!refined(string rid) : refined(rid) {
        console.println("Already refined: " + rid);
    }

    // "" MEANS-END: draft ' check ' revise ' accept ""
    rule +!refined(string draftRid) {
        string draftText = gl.field(draftRid, "answer");
        console.println("[Draft] " + draftText);

        // Check
        string checkRid = gl.ask("agent1", "step2",
            "Review this text and suggest improvements: " + draftText);
        string notes = gl.field(checkRid, "answer");
        console.println("[Check] " + notes);

        // Revise
        string finalRid = gl.ask("agent1", "step3",
            "Revise this text: " + draftText + " Based on: " + notes);
        string revised = gl.field(finalRid, "answer");
        console.println("[Revised] " + revised);

        // Accept the final candidate
        string cid = gl.candidate(finalRid);
        gl.accept(cid);
        +refined(draftRid);
        console.println("Final candidate ' ACCEPTED");
    }

    // "" RECOVERY ""
    rule -!refined(string rid) : ~refined(string _) {
        console.println("Pipeline FAILED for " + rid);
    }
}
