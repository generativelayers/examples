// Pipeline: main > !classified(food) > !deliberated > accept|reject
// Pattern 1: Simple Validation - ASTRA (GL v2)
//
// The simplest governance pattern: accept valid output, reject invalid.
// Demonstrates the fundamental decide() context-guard branching.
agent PatternRunner {
    module gl.astra.GL gl;
    module Console console;
    module System S;

    types governance {
        formula binding(string);
        formula validated(string);
        formula accepted(string);
        formula rejected(string);
        formula classified(string, string, string);
    }

    inference validated(string cid) :- accepted(cid);
    inference validated(string cid) :- rejected(cid);

    rule +!main(list args) {
        !banner();
        +binding(gl.bind("agent1", "groq", "llama-3.3-70b-versatile", ""));
        !classified("apple");
        !shutdown();
    }

    // ACHIEVEMENT: clean exit
    rule +!shutdown() {
        S.exit();
    }

    // ACHIEVEMENT: display banner
    rule +!banner() {
        console.println("=== Pattern 1: Simple Validation (GL v2) ===");
        console.println("");
        console.println("[Layer] Available providers: " + gl.see());
    }

    // DECOMPOSITION: classify = call + deliberate
    rule +!classified(string foodItem) : binding(string bid) {
        !deliberated(gl.call(bid, "classify_food", "llm.answer", "ANSWER",
            "Classify the food item '" + foodItem + "'. Return label and confidence.",
            "label,confidence", ""));
    }

    // SERENDIPITY: already deliberated
    rule +!deliberated(string rid) : validated(gl.candidate(rid)) {
        console.println("[AGENT] Already deliberated: " + rid);
    }

    // DECOMPOSITION: admissible > accept + trace
    rule +!deliberated(string rid) : gl.decide(gl.candidate(rid)) == "ADMISSIBLE" {
        !accepted_candidate(rid, gl.candidate(rid));
        !print_trace(rid);
    }

    // DECOMPOSITION: not admissible > reject + trace
    rule +!deliberated(string rid) {
        !rejected_candidate(gl.candidate(rid), rid);
        !print_trace(rid);
    }

    // ACHIEVEMENT: accept (actions only)
    rule +!accepted_candidate(string rid, string cid) {
        console.println("");
        console.println("[AGENT] Candidate is ADMISSIBLE.");
        console.println("[AGENT]   label      = " + gl.get(cid, "label"));
        console.println("[AGENT]   confidence = " + gl.get(cid, "confidence"));
        gl.accept(cid, "valid classification");
        +accepted(cid);
        +classified("food", gl.get(cid, "label"), gl.get(cid, "confidence"));
        console.println("[AGENT] Candidate ACCEPTED. Belief adopted.");
    }

    // ACHIEVEMENT: reject (actions only)
    rule +!rejected_candidate(string cid, string rid) {
        gl.reject(cid, "failed validation");
        +rejected(cid);
        console.println("");
        console.println("[AGENT] Candidate REJECTED.");
        console.println("[AGENT]   reason = " + gl.explain(rid));
    }

    // ACHIEVEMENT: print trace
    rule +!print_trace(string rid) {
        console.println("");
        console.println("[TRACE] " + gl.explain(rid));
        console.println("=== Demo Complete ===");
    }

    // RECOVERY: only fire when no candidate was accepted (genuine failure)
    rule -!classified(string foodItem) : ~accepted(string _) {
        console.println("[AGENT] Classification FAILED for " + foodItem);
    }

    rule -!deliberated(string rid) : ~accepted(string _) {
        console.println("[AGENT] Deliberation FAILED for " + rid);
    }
}
