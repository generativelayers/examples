// Pipeline: main > !inspected > !known_category > ?inspected
// Pattern 2: Content Inspection - ASTRA
//
// After validation, inspects the LLM output against the agent's
// own knowledge base. Accepts only if the label is a known category.
agent PatternRunner {
    module gl.astra.GL gl;
    module Console console;
    module System S;

    types governance {
        formula binding(string);
        formula inspected(string);
        formula accepted(string);
        formula rejected(string);
        formula known(string);
    }

    initial known("fruit"), known("vegetable"), known("grain");

    // DOMAIN MODEL
    inference inspected(string cid) :- accepted(cid);
    inference inspected(string cid) :- rejected(cid);

    // DECOMPOSITION: main only adopts subgoals
    rule +!main(list args) {
        !banner();
        !setup();
        !classified("apple");
        !shutdown();
    }

    // ACHIEVEMENT: display banner
    rule +!banner() {
        console.println("=== Pattern 2: Content Inspection ===");
        console.println("");
    }

    // ACHIEVEMENT: setup binding
    rule +!setup() {
        +binding(gl.bind("agent1", "groq", "llama-3.3-70b-versatile", ""));
    }

    // ACHIEVEMENT: clean exit
    rule +!shutdown() {
        S.exit();
    }

    // DECOMPOSITION: classify = call + inspect
    rule +!classified(string item) : binding(string bid) {
        !inspected(gl.call(bid, "classify", "llm.answer", "ANSWER",
            "Classify: " + item + ". Return label and confidence.",
            "label,confidence", "category(" + item + ", fruit)"));
    }

    // SERENDIPITY: already inspected
    rule +!inspected(string rid) : inspected(gl.candidate(rid)) {
        console.println("Already inspected: " + rid);
    }

    // DECOMPOSITION: admissible > check content against knowledge base
    rule +!inspected(string rid) : gl.decide(gl.candidate(rid)) == "ADMISSIBLE" {
        !known_category(rid, gl.candidate(rid), gl.get(gl.candidate(rid), "label"));
    }

    // ACHIEVEMENT: not admissible > reject
    rule +!inspected(string rid) {
        gl.reject(gl.candidate(rid), "output not admissible");
        +rejected(gl.candidate(rid));
        console.println("Invalid output - REJECTED");
    }

    // ACHIEVEMENT: known category > accept
    rule +!known_category(string rid, string cid, string label) : known(label) {
        gl.accept(cid, "known category: " + label);
        +accepted(cid);
        console.println("Known category '" + label + "' - ACCEPTED");
        console.println("  confidence = " + gl.get(cid, "confidence"));
        console.println("");
        console.println("[TRACE] " + gl.explain(rid));
        console.println("=== Demo Complete ===");
    }

    // ACHIEVEMENT: unknown category > reject
    rule +!known_category(string rid, string cid, string label) : ~known(label) {
        gl.reject(cid, "unknown category: " + label);
        +rejected(cid);
        console.println("Unknown category '" + label + "' - REJECTED");
        console.println("");
        console.println("[TRACE] " + gl.explain(rid));
        console.println("=== Demo Complete ===");
    }

    // RECOVERY
    rule -!inspected(string rid) : ~accepted(string _) & ~rejected(string _) {
        console.println("Inspection FAILED for " + rid);
    }
}
