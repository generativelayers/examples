// Pipeline: main > !configured > !consistent > !belief_checked
/**
 * Pattern 6: Belief Consistency - ASTRA
 *
 * Compare the LLM candidate with existing beliefs. Confirm matches,
 * reject contradictions, adopt new facts only when no prior belief exists.
 */
agent PatternRunner {
    module gl.astra.GL gl;
    module Console console;
    module System S;

    types governance {
        formula setting(string, string);
        formula configured(boolean);
        formula confirmed(string);
        formula rejected(string);
        formula adopted_new(string);
        formula consistent(string);
        formula category(string, string);
    }

    initial setting("model", "gpt-oss-120b"), setting("provider", "cerebras");
    initial category("apple", "fruit"), category("carrot", "vegetable");

    inference consistent(string rid) :- confirmed(rid);
    inference consistent(string rid) :- rejected(rid);
    inference consistent(string rid) :- adopted_new(rid);

    rule +!main(list args) {
        !configured(true);
        !consistent(gl.ask("agent1", "classify", "Classify: apple"));
        !shutdown();
    }

    // ACHIEVEMENT: clean exit (actions only)
    rule +!shutdown() {
        S.exit();
    }

    rule +!configured(boolean x) : setting("model", string m) & setting("provider", string p) {
        gl.configure("model", m);
        gl.use_provider(p);
    }

    rule +!consistent(string rid) : consistent(rid) {
        console.println("Already checked: " + rid);
    }

    rule +!consistent(string rid) : gl.valid(rid) == true {
        !belief_checked(rid, "apple", gl.field(rid, "label"), gl.candidate(rid));
    }

    rule +!consistent(string rid) {
        gl.reject(gl.candidate(rid));
        +rejected(rid);
        console.println("Invalid output - REJECTED");
    }

    rule +!belief_checked(string rid, string item, string label, string cid) : category(item, label) {
        gl.accept(cid);
        +confirmed(rid);
        console.println("Matches belief - CONFIRMED");
    }

    rule +!belief_checked(string rid, string item, string label, string cid) : category(item, string existing) & ~category(item, label) {
        gl.reject(cid);
        +rejected(rid);
        console.println("Contradicts belief - REJECTED");
    }

    rule +!belief_checked(string rid, string item, string label, string cid) : ~category(item, string any) {
        gl.accept(cid);
        +category(item, label);
        +adopted_new(rid);
        console.println("No prior belief - NEW KNOWLEDGE");
    }

    rule -!consistent(string rid) : ~confirmed(string _) & ~rejected(string _) & ~adopted_new(string _) {
        console.println("Consistency check FAILED for " + rid);
    }
}
