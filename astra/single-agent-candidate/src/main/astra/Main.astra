/**
 * Single Agent Candidate — Generative Layer demonstration.
 *
 * Shows the fundamental Generative Layer flow:
 *   configure → use_provider → invoke → validate → accept/reject
 *
 * The agent chooses its own provider and model, then asks the generative layer
 * to classify a food item. No generated output enters beliefs
 * without explicit agent action.
 */
agent Main {
    module gl.adapter.astra.AstraAdapter gl;
    module Console console;

    types gl_types {
        formula candidate_accepted(string);
        formula candidate_rejected(string);
        formula classification(string, string);
    }

    rule +!main(list args) {
        console.println("=== Generative Layer Single Agent Candidate Demo ===");
        console.println("");

        // Step 0 — List available providers
        console.println("[Layer] Available providers: " + gl.providers());

        // Step 1 — Configure the provider (agent chooses!)
        // Options: gl.use_provider("gemini");
        //          gl.use_provider("gemini", "gemini-2.5-flash");
        //          gl.use_provider("openai", "gpt-4o-mini");
        //          gl.use_provider("fake");
        //
        // Or fine-grained:
        //   gl.configure("provider", "gemini");
        //   gl.configure("model", "gemini-2.5-flash");
        //   gl.configure("temperature", "0.1");
        //   gl.use_provider();
        //
        // No-arg auto-detects from GL_PROVIDER / GL_MODEL env vars.
        // Default: "fake" for offline testing.
        gl.use_provider();

        // Step 2 — Invoke the generative resource
        string resultId = gl.invoke(
            "agent_a",                  // agentId
            "classify_food",            // goalId
            "llm.answer",              // bodyId (generative body)
            "ANSWER",                  // affordance type
            "Classify the food item 'apple'. What category does it belong to? (e.g. fruit, vegetable, grain, dairy, meat). Return label (the category) and confidence (0 to 1).",
            "label,confidence"         // required fields for validation
        );

        console.println("[Layer] resultId  = " + resultId);
        console.println("[Layer] outcome   = " + gl.outcome(resultId));
        boolean isValid = gl.valid(resultId);
        console.println("[Layer] valid     = " + isValid);

        // Step 3 — Get the candidate handle
        string candidateId = gl.candidate(resultId);
        console.println("[Layer] candidate = " + candidateId);

        // Step 4 — Agent deliberation: inspect, then accept or reject
        boolean isAdmissible = gl.admissible(candidateId);

        if (isValid & isAdmissible) {
            string label      = gl.field(resultId, "label");
            string confidence  = gl.field(resultId, "confidence");

            console.println("");
            console.println("[AGENT] Candidate is valid and admissible.");
            console.println("[AGENT]   label      = " + label);
            console.println("[AGENT]   confidence = " + confidence);

            gl.accept(candidateId);
            +candidate_accepted(candidateId);
            +classification(label, confidence);

            console.println("[AGENT] Candidate ACCEPTED. Belief adopted.");
        } else {
            if (candidateId ~= "") {
                gl.reject(candidateId);
            }
            +candidate_rejected(candidateId);

            console.println("");
            console.println("[AGENT] Candidate REJECTED.");
            console.println("[AGENT]   outcome = " + gl.outcome(resultId));
        }

        // Step 5 — Trace for auditability
        string traceId = gl.trace(resultId);
        console.println("");
        console.println("[TRACE] traceId = " + traceId);
        console.println("=== Demo Complete ===");
    }
}
