// Pipeline: main > !configured > !try_classify(strict) > !try_classify(relaxed) > !deliberated > accept|reject
agent Main {
    module gl.astra.GL gl;
    module Console console;
    module System S;

    types governance {
        formula binding(string);
        formula accepted(string);
        formula rejected(string, string);
        formula classification(string, string, string);
        formula attempt(int);
    }

    initial attempt(0);

    // DECOMPOSITION: main only adopts subgoals
    rule +!main(list args) {
        !banner();
        +binding(gl.bind("agent_a", "groq", "llama-3.3-70b-versatile", ""));
        !try_classify(
            "Classify 'banana' as food. Return label, confidence, and category.",
            "label,confidence,category", 1
        );
        !try_classify(
            "Classify 'banana' as food. Return label and confidence.",
            "label,confidence", 2
        );
        !demo_complete();
        !shutdown();
    }

    // ACHIEVEMENT: clean exit (actions only)
    rule +!shutdown() {
        S.exit();
    }

    // ACHIEVEMENT: display banner
    rule +!banner() {
        console.println("=== Generative Layer Invalid Output Rejection Demo ===");
        console.println("");
    }

    // ACHIEVEMENT: display demo complete
    rule +!demo_complete() {
        console.println("");
        console.println("=== Demo Complete ===");
    }

    // DECOMPOSITION: classify = log attempt > call > deliberate
    rule +!try_classify(string prompt, string requiredCsv, int attemptNum) : binding(string bid) {
        !log_attempt(attemptNum, requiredCsv);
        !deliberated(
            gl.call(bid, "classify_food", "llm.answer", "ANSWER", prompt, requiredCsv, ""),
            attemptNum);
    }

    // ACHIEVEMENT: log attempt
    rule +!log_attempt(int attemptNum, string requiredCsv) {
        console.println("[ATTEMPT " + attemptNum + "] Invoking gl...");
        console.println("[ATTEMPT " + attemptNum + "]   required = " + requiredCsv);
    }

    // DECOMPOSITION: handle deliberation based on outcome
    rule +!deliberated(string rid, int attemptNum) : gl.decide(gl.candidate(rid)) == "ADMISSIBLE" {
        !accepted_candidate(rid, gl.candidate(rid), attemptNum);
    }

    rule +!deliberated(string rid, int attemptNum) {
        !rejected_candidate(gl.candidate(rid), rid, attemptNum);
    }

    // ACHIEVEMENT: accept (actions only)
    rule +!accepted_candidate(string rid, string cid, int attemptNum) {
        console.println("[ATTEMPT " + attemptNum + "]   outcome  = " + gl.decide(cid));
        console.println("[ATTEMPT " + attemptNum + "]   valid    = true");

        gl.accept(cid, "admissible output");
        +accepted(cid);
        +classification(gl.get(cid, "label"), gl.get(cid, "confidence"), "attempt_" + attemptNum);
        -+attempt(attemptNum);

        console.println("[ATTEMPT " + attemptNum + "]   ACCEPTED");
        console.println("[ATTEMPT " + attemptNum + "]     label      = " + gl.get(cid, "label"));
        console.println("[ATTEMPT " + attemptNum + "]     confidence = " + gl.get(cid, "confidence"));
        console.println("");
    }

    // ACHIEVEMENT: reject (actions only)
    rule +!rejected_candidate(string cid, string rid, int attemptNum) {
        console.println("[ATTEMPT " + attemptNum + "]   outcome  = " + gl.decide(cid));
        console.println("[ATTEMPT " + attemptNum + "]   valid    = false");

        if (cid ~= "") {
            gl.reject(cid, "failed validation/deliberation");
        }
        +rejected(cid, gl.decide(cid));
        -+attempt(attemptNum);

        console.println("[ATTEMPT " + attemptNum + "]   REJECTED: " + gl.decide(cid));
        console.println("[ATTEMPT " + attemptNum + "]   No beliefs adopted. Fail-closed.");
        console.println("");
    }

    // RECOVERY: only fire when pipeline never completed (attempt still at 0)
    rule -!try_classify(string prompt, string requiredCsv, int attemptNum) : attempt(0) {
        console.println("[ATTEMPT " + attemptNum + "] Classification FAILED");
    }

    rule -!deliberated(string rid, int attemptNum) : attempt(0) {
        console.println("[ATTEMPT " + attemptNum + "] Deliberation FAILED");
    }
}
