// Pipeline: main ' !configured ' !try_classify(strict) ' !try_classify(relaxed) ' !deliberated ' accept|reject
agent Main {
    module gl.astra.GL gl;
    module Console console;
    module System S;

    types governance {
        formula setting(string, string);
        formula configured(boolean);
        formula accepted(string);
        formula rejected(string, string);
        formula classification(string, string, string);
        formula attempt(int);
    }

    initial setting("model", "gpt-oss-120b"), setting("provider", "cerebras");
    initial attempt(0);

    // DECOMPOSITION: main only adopts subgoals
    rule +!main(list args) {
        !banner();
        !configured(true);
        !try_classify(
            "Classify 'banana' as food. Return label, confidence, and category.",
            "label,confidence,category", 1
        );
        !try_classify(
            "Classify 'banana' as food. Return label and confidence.",
            "label,confidence", 2
        );
        !demo_complete();
        !shutdown();
    }

    // ACHIEVEMENT: clean exit (actions only)
    rule +!shutdown() {
        S.exit();
    }

    // ACHIEVEMENT: display banner
    rule +!banner() {
        console.println("=== Generative Layer Invalid Output Rejection Demo ===");
        console.println("");
    }

    // ACHIEVEMENT: display demo complete
    rule +!demo_complete() {
        console.println("");
        console.println("=== Demo Complete ===");
    }

    // ACHIEVEMENT: setup
    rule +!configured(boolean x) : setting("model", string m) & setting("provider", string p) {
        gl.configure("model", m);
        gl.use_provider(p);
    }

    // DECOMPOSITION: classify = log attempt ' invoke ' deliberate
    rule +!try_classify(string prompt, string requiredCsv, int attemptNum) {
        !log_attempt(attemptNum, requiredCsv);
        !deliberated(
            gl.invoke("agent_a", "classify_food", "llm.answer", "ANSWER", prompt, requiredCsv),
            attemptNum);
    }

    // ACHIEVEMENT: log attempt
    rule +!log_attempt(int attemptNum, string requiredCsv) {
        console.println("[ATTEMPT " + attemptNum + "] Invoking gl...");
        console.println("[ATTEMPT " + attemptNum + "]   required = " + requiredCsv);
    }

    // ACHIEVEMENT: valid ' accept
    rule +!deliberated(string rid, int attemptNum) : gl.valid(rid) == true {
        console.println("[ATTEMPT " + attemptNum + "]   outcome  = " + gl.outcome(rid));
        console.println("[ATTEMPT " + attemptNum + "]   valid    = true");

        gl.accept(gl.candidate(rid));
        +accepted(gl.candidate(rid));
        +classification(gl.field(rid, "label"), gl.field(rid, "confidence"), "attempt_" + attemptNum);
        -+attempt(attemptNum);

        console.println("[ATTEMPT " + attemptNum + "]   ACCEPTED");
        console.println("[ATTEMPT " + attemptNum + "]     label      = " + gl.field(rid, "label"));
        console.println("[ATTEMPT " + attemptNum + "]     confidence = " + gl.field(rid, "confidence"));
        console.println("");
    }

    // ACHIEVEMENT: invalid ' reject (fail-closed)
    rule +!deliberated(string rid, int attemptNum) : gl.valid(rid) == false {
        console.println("[ATTEMPT " + attemptNum + "]   outcome  = " + gl.outcome(rid));
        console.println("[ATTEMPT " + attemptNum + "]   valid    = false");

        gl.reject(gl.candidate(rid));
        +rejected(gl.candidate(rid), gl.outcome(rid));
        -+attempt(attemptNum);

        console.println("[ATTEMPT " + attemptNum + "]   REJECTED " " + gl.outcome(rid));
        console.println("[ATTEMPT " + attemptNum + "]   No beliefs adopted. Fail-closed.");
        console.println("");
    }

    // RECOVERY: only fire when pipeline never completed (attempt still at 0)
    rule -!try_classify(string prompt, string requiredCsv, int attemptNum) : attempt(0) {
        console.println("[ATTEMPT " + attemptNum + "] Classification FAILED");
    }

    rule -!deliberated(string rid, int attemptNum) : attempt(0) {
        console.println("[ATTEMPT " + attemptNum + "] Deliberation FAILED");
    }
}
